{
  "name": "klaus-ai",
  "version": "0.1.22",
  "description": "Use Claude Code from QQ, WeChat Work, or any messaging platform",
  "type": "module",
  "bin": {
    "klaus": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "install.sh",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "chatbot",
    "qq-bot",
    "wecom",
    "wechat-work"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@clack/prompts": "^0.10.0",
    "better-sqlite3": "^12.6.2",
    "fast-xml-parser": "^5.2.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
