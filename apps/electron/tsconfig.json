{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "bun:bundle": ["./src/engine/shims/bun-bundle.ts"],
      "@anthropic-ai/mcpb": ["./src/engine/shims/pkg-mcpb.ts"],
      "@anthropic-ai/sandbox-runtime": ["./src/engine/shims/pkg-sandbox-runtime.ts"],
      "src/constants/*": ["./src/engine/constants/*"],
      "src/utils/*": ["./src/engine/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
